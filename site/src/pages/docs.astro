---
import LandingLayout from "../layouts/LandingLayout.astro";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
---

<LandingLayout>
  <Nav />
  <main class="docs">
    <h1>Documentation</h1>
    <p class="docs-sub">Getting started guides, configuration, and reference.</p>
    <section class="docs-section">
      <h2>Quick Start</h2>
      <p>Coming soon.</p>
    </section>
  </main>
  <Footer />
</LandingLayout>

<style>
  .docs {
    max-width: 680px;
    margin: 0 auto;
    padding: 48px 32px;
    min-height: 60vh;
  }
  .docs h1 {
    font-size: 32px;
    font-weight: 600;
    letter-spacing: -0.02em;
    color: var(--ea-text-primary);
    margin: 0 0 8px;
  }
  .docs-sub {
    font-size: 14px;
    color: var(--ea-text-secondary);
    margin: 0 0 32px;
  }
  .docs-section h2 {
    font-size: 20px;
    font-weight: 600;
    color: var(--ea-text-primary);
    margin: 0 0 8px;
  }
  .docs-section p {
    font-size: 14px;
    color: var(--ea-text-tertiary);
    margin: 0;
  }
</style>
