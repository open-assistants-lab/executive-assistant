# ================================
# Executive Assistant — Environment
# ================================
# Copy this file to .env and fill in your values.
# Secrets only — non-sensitive config lives in config.yaml.

# ================================
# LLM Provider API Keys
# ================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama (local or cloud)
OLLAMA_BASE_URL=https://ollama.com
OLLAMA_API_KEY=

# ================================
# Web Scraping (Firecrawl)
# ================================
FIRECRAWL_API_KEY=
# FIRECRAWL_BASE_URL=  # For self-hosted, e.g., http://localhost:3002

# ================================
# Langfuse (optional - observability)
# ================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=         # Default: https://cloud.langfuse.com
# LANGFUSE_ENVIRONMENT=  # production, development, staging

# ================================
# API Auth (for WAN / multi-tenant)
# ================================
# Set this to enable API key auth on non-localhost connections.
# Each multi-tenant container gets its own key.
# EA_API_KEY=
# EA_SOLO_BYPASS=true   # Skip auth for localhost connections

# ================================
# OAuth Credentials (Google Workspace)
# ================================
# Set to your Google Cloud OAuth Desktop client credentials to enable
# out-of-the-box Google Workspace integration.
# EMAIL_GWS_CLIENT_ID=
# EMAIL_GWS_CLIENT_SECRET=
# EMAIL_M365_CLIENT_ID=

# ConnectKit Vault Key — set to persist OAuth tokens across restarts
# CONNECTKIT_VAULT_KEY=
