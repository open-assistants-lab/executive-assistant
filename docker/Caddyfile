# Caddyfile for Executive Assistant

# HTTPS site
ea.mgmtcnsltng.com {
    # Reverse proxy to app container
    reverse_proxy app:8000

    # Enable HTTP/3
    protocols h1 h2 h3

    # Compression
    encode zstd gzip

    # Log format
    log {
        output file /var/log/caddy/access.log
    }
}

# HTTP to HTTPS redirect
http:// {
    # Redirect all HTTP to HTTPS
    redir https://{host}{uri} permanent
}
