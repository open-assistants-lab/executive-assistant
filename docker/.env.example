# ================================
# Application
# ================================
APP_ENV=production
APP_DEBUG=false

# ================================
# Agent Configuration
# ================================
AGENT_NAME=Executive Assistant

# ================================
# LLM Provider API Keys
# ================================
# Set your LLM provider API keys here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-12-01-preview
GROQ_API_KEY=
XAI_API_KEY=
NVIDIA_API_KEY=
COHERE_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
FIREWORKS_API_KEY=
DEEPSEEK_API_KEY=
HUGGINGFACE_API_KEY=
OPENROUTER_API_KEY=

# Ollama (local or cloud endpoint)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_API_KEY=
OLLAMA_TIMEOUT_SECONDS=45

# AWS (for Bedrock/Nova)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Databricks
DATABRICKS_HOST=
DATABRICKS_TOKEN=

# IBM Watsonx
WATSONX_URL=
WATSONX_APIKEY=

# Llama.cpp (local model path)
LLAMACPP_MODEL_PATH=

# Minimax (Chinese LLM)
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=

# Qwen (Alibaba Cloud / Dashscope)
DASHSCOPE_API_KEY=

# Zhipu AI (GLM models)
ZHIPUAI_API_KEY=

# ================================
# Default Model Configuration
# ================================
# Main chat model (format: provider/model-name)
DEFAULT_MODEL=ollama/llama3.2

# Summarization model
SUMMARIZATION_MODEL=ollama/llama3.2

# ================================
# Langfuse (optional - observability)
# ================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

# ================================
# Database
# ================================
DATABASE_URL=postgresql+asyncpg://ea:testpassword123@db:5432/ea_db

# ================================
# API Server
# ================================
API_HOST=0.0.0.0
API_PORT=8000

# ================================
# Web Search (Tavily)
# ================================
TAVILY_API_KEY=

# ================================
# Web Scraping (Firecrawl)
# ================================
FIRECRAWL_API_KEY=
FIRECRAWL_BASE_URL=http://host.docker.internal:3002

# ================================
# Checkpointer (SQLite)
# ================================
CHECKPOINT_ENABLED=false
