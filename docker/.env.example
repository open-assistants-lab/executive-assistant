# Executive Assistant - Environment Variables

# ===========================================
# REQUIRED: LLM Configuration
# ===========================================

# Ollama (local) - leave empty if using cloud
# Get API key from https://ollama.com
OLLAMA_API_KEY=

# Ollama base URL (local or cloud)
# For local: http://host.docker.internal:11434
# For cloud: https://api.ollama.com
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ===========================================
# OPTIONAL: Firecrawl (Web Search & Scraping)
# ===========================================

# Option 1: Self-hosted Firecrawl (recommended - no API key needed)
# Set the URL of your self-hosted Firecrawl instance
FIRECRAWL_BASE_URL=http://host.docker.internal:3002

# Option 2: Firecrawl Cloud (requires API key)
# Get free key at https://firecrawl.dev
# FIRECRAWL_API_KEY=your-api-key

# ===========================================
# OPTIONAL: Telegram Bot
# ===========================================

# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ===========================================
# OPTIONAL: Logging
# ===========================================

# Log level: debug, info, warning, error
LOG_LEVEL=info
